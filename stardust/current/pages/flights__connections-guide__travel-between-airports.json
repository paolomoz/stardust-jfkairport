    },
    {
      "index": 3,
      "tag": "section",
      "id": "",
      "className": "chakra-stack css-sekf8j",
      "ariaLabel": "",
      "heading": "",
      "textPreview": "You can use Uber, Lyft, and other ride apps to connect between airports. Trips may be subject to additional tolls and surcharges depending on time of day, route traveled, and other factors",
