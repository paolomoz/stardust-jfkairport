        }
      ]
    },
    {
      "index": 2,
      "tag": "section",
      "id": "",
      "className": "chakra-stack css-sekf8j",
      "ariaLabel": "",
      "heading": "",
      "textPreview": "Taxis offer reliable transportation between airports, and you will find them waiting outside each terminal—just follow the signs. Taxis between JFK and LGA Estimated travel time: 30-60 minutes Estimated fare: $60 Taxis between JFK and EWR Estimated travel time: 60-100 minutes Est",
      "rect": {
        "x": 744,
        "y": 1200,
        "w": 382.7,
        "h": 396
      },
      "styles": {
        "backgroundColor": "rgba(0, 0, 0, 0)",
