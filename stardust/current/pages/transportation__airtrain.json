    {
      "index": 3,
      "tag": "section",
      "id": "",
      "className": "chakra-stack css-sekf8j",
      "ariaLabel": "",
      "heading": "",
      "textPreview": "The AirTrain takes passengers between terminals at JFK in under 10 minutes. This is a free, convenient service to access your connecting gate. Trains run every 5-10 minutes, but be sure to check monitors in the AirTrain station for any service changes.",
      "rect": {
        "x": 297.3,
        "y": 2057.3,
        "w": 255.1,
        "h": 264
      },
      "styles": {
        "backgroundColor": "rgba(0, 0, 0, 0)",
