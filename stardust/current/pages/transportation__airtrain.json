    {
      "index": 5,
      "tag": "section",
      "id": "",
      "className": "chakra-stack css-sekf8j",
      "ariaLabel": "",
      "heading": "",
      "textPreview": "You can easily access parking areas by taking the AirTrain. Each terminal is a short walk to its nearby short-term parking lot. Long-term parking is available near the Lefferts Boulevard Station.",
